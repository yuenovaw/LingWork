page {
  background: #F5F7FF;
}

.page {
  padding: 28rpx;
  color: #111827;
}

.top-card {
  background: linear-gradient(135deg, #1E40AF 0%, #3B82F6 60%, #60A5FA 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 14rpx 40rpx rgba(37, 99, 235, 0.38);
}

.top-title {
  font-size: 42rpx;
  font-weight: 900;
  color: #fff;
}

.top-sub {
  color: rgba(255, 255, 255, 0.82);
  font-size: 30rpx;
  line-height: 1.55;
  margin-top: 10rpx;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.07);
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1E40AF;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.brand-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 0 0 10rpx;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.07);
  border-left: 6rpx solid #3B82F6;
}

.brand-logo {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.35;
  color: #111827;
}

.brand-desc {
  color: #6B7280;
  font-size: 27rpx;
  line-height: 1.45;
  margin-top: 6rpx;
}

.setting-row,
.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  min-height: 100rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #EEF2FF;
}

.setting-row:last-child,
.switch-row:last-child {
  border-bottom: none;
}

.setting-row:active {
  opacity: 0.7;
}

.row-title {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
  color: #111827;
}

.row-sub {
  color: #6B7280;
  font-size: 28rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.setting-row text {
  color: #9CA3AF;
  font-size: 44rpx;
  flex-shrink: 0;
}

.auth-panel {
  background: #DBEAFE;
  color: #1E40AF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 18rpx 0 8rpx;
}

.auth-status {
  font-size: 32rpx;
  font-weight: 900;
}

.auth-desc {
  color: #1D4ED8;
  font-size: 28rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}

.safe-note {
  background: #EEF2FF;
  color: #374151;
  border: 2rpx solid #DBEAFE;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  margin-top: 18rpx;
  margin-bottom: 8rpx;
}
