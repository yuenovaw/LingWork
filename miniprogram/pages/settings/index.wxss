page {
  background: #f7fcf9;
}

.page {
  padding: 28rpx;
  color: #24362c;
}

.top-card,
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e3f1e8;
  box-shadow: 0 10rpx 24rpx rgba(79, 139, 97, 0.06);
}

.top-title {
  font-size: 40rpx;
  font-weight: 800;
}

.top-sub {
  color: #7d746a;
  font-size: 30rpx;
  line-height: 1.55;
  margin-top: 10rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.brand-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: #fff;
  border: 2rpx solid #e3f1e8;
  border-radius: 22rpx;
  padding: 24rpx;
  margin: 0 0 10rpx;
  box-shadow: 0 10rpx 24rpx rgba(79, 139, 97, 0.06);
}

.brand-logo {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.brand-name {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
}

.brand-desc {
  color: #7d746a;
  font-size: 27rpx;
  line-height: 1.45;
  margin-top: 6rpx;
}

.setting-row,
.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  min-height: 104rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #e1eee6;
}

.setting-row:last-child,
.switch-row:last-child {
  border-bottom: none;
}

.row-title {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.row-sub {
  color: #7d746a;
  font-size: 28rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.setting-row text {
  color: #b5aca2;
  font-size: 44rpx;
  flex-shrink: 0;
}

.auth-panel {
  background: #e7f7ef;
  color: #3f8b62;
  border-radius: 14rpx;
  padding: 22rpx;
  margin: 18rpx 0 8rpx;
}

.auth-status {
  font-size: 32rpx;
  font-weight: 800;
}

.auth-desc {
  color: #456955;
  font-size: 28rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}

.safe-note {
  background: #f1faf4;
  color: #6f604e;
  border: 2rpx solid #d8efdf;
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 30rpx;
  line-height: 1.6;
  margin-top: 18rpx;
  margin-bottom: 8rpx;
}
