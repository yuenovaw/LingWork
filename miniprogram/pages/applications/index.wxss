page {
  background: #F5F7FF;
}

.page {
  padding: 28rpx;
  color: #111827;
}

/* 顶部标题卡 */
.top-card {
  background: linear-gradient(135deg, #1E40AF 0%, #3B82F6 60%, #60A5FA 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 14rpx 40rpx rgba(37, 99, 235, 0.38);
}

.title {
  font-size: 46rpx;
  font-weight: 900;
  color: #fff;
}

.hint {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 30rpx;
  line-height: 1.5;
}

/* 空状态 */
.empty {
  background: #fff;
  border-radius: 20rpx;
  padding: 44rpx 32rpx;
  border-left: 6rpx solid #3B82F6;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.08);
}

.empty-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #374151;
}

.empty-text {
  color: #9CA3AF;
  font-size: 30rpx;
  margin-top: 12rpx;
  line-height: 1.5;
}

/* 申请卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #3B82F6;
  box-shadow: 0 4rpx 20rpx rgba(37, 99, 235, 0.09);
  transition: background-color 0.15s;
}

.card:active {
  background-color: #F0F4FF;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.job-title {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.28;
  color: #111827;
}

/* 状态徽章 */
.badge {
  flex-shrink: 0;
  color: #1E40AF;
  background: #DBEAFE;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  font-size: 27rpx;
  font-weight: 700;
}

.badge.ok {
  color: #065F46;
  background: #D1FAE5;
}

.salary {
  color: #1D4ED8;
  font-size: 56rpx;
  font-weight: 900;
  margin-top: 16rpx;
  letter-spacing: -1rpx;
}

.meta {
  color: #6B7280;
  font-size: 30rpx;
  margin-top: 10rpx;
}

/* 保险徽章 */
.insurance {
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.insurance.safe {
  background: #D1FAE5;
  color: #065F46;
}

.insurance.warn {
  background: #FEF3C7;
  color: #92400E;
}

.insurance.pending {
  background: #F3F4F6;
  color: #6B7280;
}

.insurance-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}

/* 三步进度条 */
.steps {
  display: flex;
  gap: 10rpx;
  margin-top: 22rpx;
}

.step {
  flex: 1;
  text-align: center;
  background: #F3F4F6;
  color: #9CA3AF;
  border-radius: 14rpx;
  padding: 16rpx 6rpx;
  font-size: 26rpx;
  font-weight: 700;
  border-bottom: 4rpx solid transparent;
}

.step.done {
  background: #DBEAFE;
  color: #1E40AF;
  border-bottom-color: #3B82F6;
}
