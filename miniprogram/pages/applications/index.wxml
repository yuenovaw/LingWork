<view class="page">
  <view class="top-card">
    <view class="title">我的报名</view>
    <view class="hint">这里能看到每个工作进行到哪一步，是否可以联系雇主。</view>
  </view>

  <view wx:if="{{loading}}" class="empty">
    <view class="empty-title">加载中...</view>
  </view>

  <view wx:elif="{{applications.length === 0}}" class="empty">
    <view class="empty-title">还没有报名</view>
    <view class="empty-text">去“找工作”看看附近合适的活。</view>
  </view>

  <view wx:for="{{applications}}" wx:key="id" class="card" bindtap="goDetail" data-job-id="{{item.jobId}}">
    <view class="card-head">
      <view class="job-title">{{item.jobTitle}}</view>
      <view class="badge {{item.canContact ? 'ok' : ''}}">{{item.statusText}}</view>
    </view>
    <view class="salary">{{item.salary}}</view>
    <view class="meta">{{item.location}} · {{item.createdAtText}}报名</view>
    <view class="insurance {{item.insuranceClass}}">
      <text class="insurance-dot"></text>
      <text>{{item.insuranceText}}</text>
    </view>
    <view class="steps">
      <view class="step {{item.workerAgreed ? 'done' : ''}}">我同意</view>
      <view class="step {{item.employerAgreed ? 'done' : ''}}">雇主同意</view>
      <view class="step {{item.canContact ? 'done' : ''}}">可联系</view>
    </view>
  </view>
</view>
