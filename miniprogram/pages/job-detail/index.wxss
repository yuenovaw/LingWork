page {
  background: #F5F7FF;
}

.page {
  padding: 28rpx 28rpx 48rpx;
  color: #111827;
}

.hero,
.section,
.safe-box {
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(37, 99, 235, 0.08);
}

.hero {
  background: linear-gradient(135deg, #1E40AF 0%, #3B82F6 60%, #60A5FA 100%);
  box-shadow: 0 16rpx 44rpx rgba(37, 99, 235, 0.38);
  color: #fff;
}

.section {
  background: #fff;
  border-left: 6rpx solid #3B82F6;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.status {
  display: inline-block;
  color: rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.22);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
  border: 2rpx solid rgba(255, 255, 255, 0.35);
}

.distance {
  color: rgba(255, 255, 255, 0.75);
  font-size: 28rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  margin-top: 24rpx;
  line-height: 1.25;
  color: #fff;
}

.salary {
  color: #fff;
  font-size: 72rpx;
  font-weight: 900;
  margin-top: 18rpx;
  letter-spacing: -2rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.plain,
.body {
  color: rgba(255, 255, 255, 0.82);
  font-size: 32rpx;
  line-height: 1.65;
  margin-top: 12rpx;
}

.section .plain,
.section .body {
  color: #374151;
}

.hero .plain {
  color: rgba(255, 255, 255, 0.75);
}

.body.strong {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
  margin-top: 22rpx;
}

.work-block {
  background: #F0F4FF;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 18rpx;
}

.work-block .body {
  margin-top: 8rpx;
  color: #374151;
}

.work-block .body.strong {
  margin-top: 0;
  color: #111827;
}

.safe-box {
  display: flex;
  gap: 18rpx;
  align-items: center;
  background: #DBEAFE;
  border-left: 6rpx solid #2563EB;
}

.safe-title,
.section-title {
  font-size: 34rpx;
  font-weight: 900;
}

.safe-title {
  color: #1E40AF;
}

.section-title {
  color: #111827;
}

.safe-text,
.locked {
  color: #1D4ED8;
  font-size: 30rpx;
  line-height: 1.6;
  margin-top: 12rpx;
}

.section .locked {
  color: #6B7280;
}

.safe-steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  width: 296rpx;
  flex-shrink: 0;
}

.safe-steps view {
  min-height: 72rpx;
  border-radius: 12rpx;
  background: #fff;
  color: #1E40AF;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.25;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.1);
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #EEF2FF;
  font-size: 31rpx;
}

.row text:first-child {
  color: #6B7280;
  flex-shrink: 0;
}

.row text:last-child {
  text-align: right;
  color: #374151;
  font-weight: 700;
}

.tags {
  margin-top: 22rpx;
}

.tag {
  display: inline-block;
  background: #EEF2FF;
  color: #1E40AF;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  margin: 0 12rpx 12rpx 0;
  font-size: 28rpx;
  font-weight: 700;
}

.contact-card {
  background: #DBEAFE;
  color: #1E40AF;
  font-size: 32rpx;
  line-height: 1.7;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-top: 20rpx;
}

.contact-card button {
  margin: 18rpx 0 0;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #1E40AF, #3B82F6);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(37, 99, 235, 0.35);
}

.bottom-space {
  height: 154rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx 34rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 2rpx solid #EEF2FF;
  box-shadow: 0 -8rpx 24rpx rgba(37, 99, 235, 0.08);
  backdrop-filter: blur(10px);
}

.primary,
.secondary {
  height: 104rpx;
  line-height: 104rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.primary {
  background: linear-gradient(135deg, #1E40AF, #3B82F6);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.38);
}

.secondary {
  background: #EEF2FF;
  color: #1E40AF;
  font-weight: 800;
}
