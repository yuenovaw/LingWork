page {
  background: #fbfaf7;
}

.page {
  min-height: 100vh;
  padding: 52rpx 36rpx;
  box-sizing: border-box;
  color: #222;
}

.panel {
  min-height: 850rpx;
  border: 4rpx solid #222;
  border-radius: 16rpx;
  background: #fff;
  padding: 36rpx 28rpx;
  box-sizing: border-box;
}

.title {
  text-align: center;
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
}

.tabs {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.tab {
  display: inline-flex;
  align-items: center;
  min-height: 62rpx;
  padding: 0 20rpx;
  margin-right: 14rpx;
  border: 3rpx solid #e6ded2;
  border-radius: 8rpx;
  color: #6f665d;
  font-size: 26rpx;
  font-weight: 800;
  background: #fbfaf7;
}

.tab.active {
  border-color: #222;
  color: #222;
  background: #f2f0ea;
}

.content {
  height: 670rpx;
  border: 3rpx solid #eee8df;
  border-radius: 10rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

.doc-title {
  color: #222;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.45;
  margin-bottom: 24rpx;
}

.p {
  color: #4f4a45;
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 22rpx;
}

.agree-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #4f4a45;
  font-size: 28rpx;
  margin-top: 34rpx;
}

.check {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border: 4rpx solid #777;
  border-radius: 6rpx;
  font-size: 28rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.check.checked {
  border-color: #222;
  background: #222;
  color: #fff;
}

.next-btn {
  width: 100%;
  height: 94rpx;
  line-height: 94rpx;
  border-radius: 10rpx;
  background: #ece8df;
  color: #928a80;
  font-size: 34rpx;
  font-weight: 800;
  border: 4rpx solid #bfb8ae;
  margin-top: 32rpx;
}

.next-btn.enabled {
  background: #f2f0ea;
  color: #222;
  border-color: #222;
}
