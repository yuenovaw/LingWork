page {
  background: #F5F7FF;
}

.page {
  min-height: 100vh;
  padding: 52rpx 36rpx;
  box-sizing: border-box;
  color: #111827;
}

.panel {
  min-height: 850rpx;
  border: 2rpx solid #DBEAFE;
  border-radius: 24rpx;
  background: #fff;
  padding: 36rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 28rpx rgba(37, 99, 235, 0.09);
}

.title {
  text-align: center;
  font-size: 38rpx;
  font-weight: 900;
  margin-bottom: 24rpx;
  color: #111827;
}

.tabs {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tab {
  display: flex;
  align-items: center;
  min-height: 72rpx;
  padding: 0 24rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  color: #6B7280;
  font-size: 28rpx;
  font-weight: 700;
  background: #F9FAFB;
}

.tab.active {
  border-color: #3B82F6;
  background: #DBEAFE;
  color: #1E40AF;
}

.content {
  height: 670rpx;
  border: 2rpx solid #EEF2FF;
  border-radius: 16rpx;
  padding: 22rpx;
  box-sizing: border-box;
  background: #FAFBFF;
}

.doc-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.45;
  margin-bottom: 24rpx;
}

.p {
  color: #374151;
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 22rpx;
}

.agree-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #374151;
  font-size: 28rpx;
  margin-top: 34rpx;
}

.check {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border: 3rpx solid #DBEAFE;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
  flex-shrink: 0;
  background: #F5F7FF;
}

.check.checked {
  border-color: #2563EB;
  background: linear-gradient(135deg, #1E40AF, #3B82F6);
  color: #fff;
}

.next-btn {
  width: 100%;
  height: 94rpx;
  line-height: 94rpx;
  border-radius: 16rpx;
  background: #E5E7EB;
  color: #9CA3AF;
  font-size: 34rpx;
  font-weight: 800;
  border: none;
  margin-top: 32rpx;
}

.next-btn.enabled {
  background: linear-gradient(135deg, #1E40AF, #3B82F6);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.38);
}
