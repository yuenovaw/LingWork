page {
  background: #F5F7FF;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
  box-sizing: border-box;
}

.landing {
  min-height: 100vh;
  padding: 34rpx 34rpx 64rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #EEF2FF 0%, #F5F7FF 100%);
}

.hero {
  min-height: 480rpx;
  padding: 44rpx 36rpx 40rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #1E40AF 0%, #3B82F6 60%, #60A5FA 100%);
  box-shadow: 0 20rpx 48rpx rgba(37, 99, 235, 0.38);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.brand-badge {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  border: 2rpx solid rgba(255, 255, 255, 0.35);
}

.brand-logo {
  width: 164rpx;
  height: 164rpx;
  margin-top: 28rpx;
  display: block;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.18);
}

.brand-title {
  margin-top: 24rpx;
  color: #fff;
  font-size: 72rpx;
  line-height: 1.08;
  font-weight: 900;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.brand-sub {
  margin-top: 18rpx;
  max-width: 560rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 30rpx;
  line-height: 1.6;
  font-weight: 700;
}

.guide-card {
  margin-top: 28rpx;
  padding: 38rpx 32rpx 32rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.1);
}

.guide-title {
  color: #111827;
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 900;
}

.guide-sub {
  margin-top: 10rpx;
  color: #6B7280;
  font-size: 28rpx;
  line-height: 1.55;
  font-weight: 600;
}

.phone-field {
  margin-top: 28rpx;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  background: #F0F4FF;
  border: 2rpx solid #DBEAFE;
}

.phone-label {
  display: block;
  color: #374151;
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 800;
}

.phone-input {
  width: 100%;
  height: 72rpx;
  margin-top: 8rpx;
  color: #111827;
  font-size: 36rpx;
  line-height: 72rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.phone-placeholder {
  color: #9CA3AF;
  font-size: 32rpx;
  font-weight: 600;
}

.primary-action {
  width: 100%;
  min-height: 128rpx;
  margin-top: 28rpx;
  padding: 24rpx 28rpx;
  border-radius: 26rpx;
  background: #93C5FD;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.primary-action.ready {
  background: linear-gradient(135deg, #1E40AF 0%, #3B82F6 60%, #60A5FA 100%);
  box-shadow: 0 16rpx 36rpx rgba(37, 99, 235, 0.38);
}

.action-copy {
  min-width: 0;
  flex: 1;
  color: #fff;
}

.action-title,
.action-desc {
  display: block;
}

.action-title {
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 900;
}

.action-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 600;
  opacity: 0.85;
}

.privacy-note {
  margin-top: 18rpx;
  color: #9CA3AF;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
  font-weight: 600;
}

.promise-list {
  margin-top: 28rpx;
  display: grid;
  gap: 16rpx;
}

.promise-item {
  min-height: 104rpx;
  padding: 22rpx 26rpx;
  border-radius: 24rpx;
  background: #fff;
  border-left: 6rpx solid #3B82F6;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.08);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.promise-mark {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1E40AF, #3B82F6);
  color: #fff;
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
  flex: 0 0 60rpx;
}

.promise-title {
  color: #111827;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 900;
}

.promise-desc {
  margin-top: 4rpx;
  color: #6B7280;
  font-size: 26rpx;
  line-height: 1.4;
  font-weight: 700;
}
