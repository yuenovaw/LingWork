page {
  background: #f5f8ff;
}

.page {
  padding: 28rpx;
  color: #24362c;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 178rpx;
  border-radius: 28rpx;
  padding: 32rpx 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #1c3f82 0%, #3468a8 55%, #5b8def 100%);
  box-shadow: 0 8rpx 28rpx rgba(36, 81, 160, 0.35);
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  line-height: 108rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
  flex-shrink: 0;
  border: 3rpx solid rgba(255, 255, 255, 0.35);
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.25;
  color: #fff;
}

.sub {
  color: rgba(255, 255, 255, 0.75);
  font-size: 29rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.verify-badge {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 25rpx;
  font-weight: 800;
  margin-top: 14rpx;
}

.phone-line {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 800;
}

.action-card,
.safe-card,
.menu {
  background: #fff;
  border-radius: 22rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 4rpx 16rpx rgba(52, 104, 168, 0.09);
  border-left: 6rpx solid transparent;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 138rpx;
}

.primary-card {
  border-left-color: #5b8def;
}

.ai-card {
  background: #edf5ff;
  border-left-color: #3468a8;
}

.action-title {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.3;
}

.action-desc {
  color: #6b6258;
  font-size: 29rpx;
  line-height: 1.45;
  margin-top: 10rpx;
}

.ai-card .action-desc {
  color: #405c85;
}

.action-arrow {
  color: #5b8def;
  font-size: 58rpx;
  font-weight: 300;
  flex-shrink: 0;
}

.ai-card button {
  width: 132rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #3f7fd0;
  color: #fff;
  font-size: 29rpx;
  font-weight: 900;
  margin: 0;
  flex-shrink: 0;
}

.safe-card {
  background: #edf5ff;
  border-left-color: #5b8def;
}

.safe-title {
  color: #3468a8;
  font-size: 34rpx;
  font-weight: 900;
}

.safe-text {
  color: #405c85;
  font-size: 30rpx;
  line-height: 1.6;
  margin-top: 10rpx;
}

.menu {
  padding: 0;
  overflow: hidden;
  border-left: 6rpx solid #dce8f8;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  min-height: 112rpx;
  padding: 22rpx 28rpx;
  border-bottom: 2rpx solid #eef3ff;
  transition: background-color 0.15s;
}

.menu-item:active {
  background-color: #f5f8ff;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
}

.menu-sub {
  color: #7d746a;
  font-size: 27rpx;
  line-height: 1.45;
  margin-top: 6rpx;
}

.menu-item text {
  color: #b5aca2;
  font-size: 46rpx;
  flex-shrink: 0;
}
