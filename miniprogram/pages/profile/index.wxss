page {
  background: #f7fcf9;
}

.page {
  padding: 28rpx;
  color: #24362c;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 178rpx;
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  background: #fff;
  color: #24362c;
  border: 2rpx solid #e3f1e8;
  box-shadow: 0 14rpx 34rpx rgba(79, 139, 97, 0.08);
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  line-height: 108rpx;
  text-align: center;
  border-radius: 50%;
  background: #eef9f2;
  color: #3f8b62;
  font-size: 44rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.25;
}

.sub {
  color: #597163;
  font-size: 29rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.verify-badge {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #eef9f2;
  color: #3f8b62;
  font-size: 25rpx;
  font-weight: 800;
  margin-top: 14rpx;
}

.phone-line {
  margin-top: 12rpx;
  color: #597163;
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 800;
}

.action-card,
.safe-card,
.menu {
  background: #fff;
  border: 2rpx solid #e3f1e8;
  border-radius: 22rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(79, 139, 97, 0.06);
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 138rpx;
}

.primary-card {
  border-color: #bde3cb;
}

.ai-card {
  background: #eefaf4;
  border-color: #cce9d8;
}

.action-title {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.3;
}

.action-desc {
  color: #6b6258;
  font-size: 29rpx;
  line-height: 1.45;
  margin-top: 10rpx;
}

.ai-card .action-desc {
  color: #406653;
}

.action-arrow {
  color: #67be86;
  font-size: 58rpx;
  font-weight: 300;
  flex-shrink: 0;
}

.ai-card button {
  width: 132rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #1da56b;
  color: #fff;
  font-size: 29rpx;
  font-weight: 900;
  margin: 0;
  flex-shrink: 0;
}

.safe-card {
  background: #eaf8f1;
  border-color: #cce9d8;
}

.safe-title {
  color: #3f8b62;
  font-size: 34rpx;
  font-weight: 900;
}

.safe-text {
  color: #406653;
  font-size: 30rpx;
  line-height: 1.6;
  margin-top: 10rpx;
}

.menu {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  min-height: 112rpx;
  padding: 22rpx 28rpx;
  border-bottom: 2rpx solid #e1eee6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
}

.menu-sub {
  color: #7d746a;
  font-size: 27rpx;
  line-height: 1.45;
  margin-top: 6rpx;
}

.menu-item text {
  color: #b5aca2;
  font-size: 46rpx;
  flex-shrink: 0;
}
