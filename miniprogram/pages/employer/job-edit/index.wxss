/**
 * 岗位编辑页
 */

.job-edit-page {
  min-height: 100vh;
  background: #F7FCF9;
  padding: 16px;
  padding-bottom: 80px;
}

.form-section {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 8px 0;
  margin-bottom: 24px;
}

.form-item {
  padding: 16px;
  border-bottom: 1px solid #F3F4F6;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 15px;
  color: #1F2937;
  margin-bottom: 12px;
}

.label.required::before {
  content: '*';
  color: #EF4444;
  margin-right: 4px;
}

.input {
  width: 100%;
  height: 48px;
  font-size: 17px;
  color: #1F2937;
}

.textarea {
  width: 100%;
  min-height: 100px;
  font-size: 17px;
  color: #1F2937;
  padding: 8px 0;
}

.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  background: #FFFFFF;
  border-top: 1px solid #E5E7EB;
  display: flex;
  gap: 12px;
}

.btn {
  flex: 1;
  height: 48px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  font-weight: 500;
}

.btn-primary {
  background: #67BE86;
  color: #FFFFFF;
}

.btn-secondary {
  background: #F3F4F6;
  color: #1F2937;
}
