/**
 * 岗位编辑页
 */

.job-edit-page {
  min-height: 100vh;
  background: #F5FBF7;
  padding: 32rpx;
  padding-bottom: 140rpx;
}

.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 0;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  border-left: 6rpx solid #10B981;
}

.form-item {
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
  font-weight: 700;
}

.label.required::before {
  content: '*';
  color: #EF4444;
  margin-right: 6rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  color: #111827;
  font-weight: 600;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 30rpx;
  color: #111827;
  padding: 8rpx 0;
  line-height: 1.6;
}

.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 2rpx solid #E5E7EB;
  display: flex;
  gap: 16rpx;
  backdrop-filter: blur(10px);
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}

.btn-primary {
  background: linear-gradient(135deg, #065F46, #10B981);
  color: #fff;
  box-shadow: 0 8rpx 22rpx rgba(6, 95, 70, 0.38);
}

.btn-secondary {
  background: #F3F4F6;
  color: #374151;
}
