/**
 * 我的页
 */

.profile-page {
  min-height: 100vh;
  background: #F5FBF7;
  padding: 32rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #111827;
  margin-bottom: 24rpx;
}

/* 个人信息卡片 */
.profile-card {
  background: linear-gradient(135deg, #065F46 0%, #10B981 60%, #34D399 100%);
  border-radius: 28rpx;
  padding: 36rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 44rpx rgba(6, 95, 70, 0.38);
  transition: opacity 0.15s;
}

.profile-card:active {
  opacity: 0.9;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50%;
  text-align: center;
  background: rgba(255, 255, 255, 0.22);
  color: #fff;
  font-size: 42rpx;
  font-weight: 900;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.38);
}

.profile-info {
  flex: 1;
}

.profile-name {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 8rpx;
}

.profile-edit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.78);
}

/* 区块 */
.section {
  margin-bottom: 20rpx;
}

.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.07);
}

/* 认证状态卡片 */
.verify-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.07);
}

.verify-status {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.verify-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.verify-icon.verified {
  background: #D1FAE5;
}

.verify-icon.unverified {
  background: #FEF3C7;
}

.verify-check {
  font-size: 36rpx;
  font-weight: 700;
}

.verify-icon.verified .verify-check {
  color: #059669;
}

.verify-icon.unverified .verify-check {
  color: #D97706;
}

.verify-info {
  flex: 1;
  line-height: 1.2;
}

.verify-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 6rpx;
}

.verify-status-text {
  display: block;
  font-size: 28rpx;
}

.verify-status-text.verified-text {
  color: #059669;
}

.verify-status-text.unverified-text {
  color: #D97706;
}

/* 菜单列表 */
.menu-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.07);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 2rpx solid #F3F4F6;
  transition: background-color 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #F0FDF4;
}

.menu-icon {
  margin-right: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #D1FAE5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.switch-worker .menu-icon {
  background: #EEF2FF;
}

.switch-worker .menu-text {
  color: #059669;
  font-weight: 700;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #111827;
  font-weight: 600;
}

.menu-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
}

/* 版本信息 */
.version {
  text-align: center;
  padding: 36rpx 0;
}

.version-text {
  font-size: 26rpx;
  color: #D1D5DB;
}
