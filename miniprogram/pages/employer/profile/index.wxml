<!--我的页-->
<view class="profile-page page-with-tabbar">
  <text class="page-title">我的</text>

  <!-- 个人信息卡片 -->
  <view class="profile-card" bindtap="onProfileEdit">
    <view class="avatar">{{avatarText}}</view>
    <view class="profile-info">
      <text class="profile-name">{{employerInfo.name}}</text>
      <text class="profile-edit">编辑个人资料 →</text>
    </view>
  </view>

  <!-- 认证状态 -->
  <view class="section">
    <view class="section-card verify-card" bindtap="onVerifyTap">
      <view class="verify-status">
        <view class="verify-icon {{employerInfo.verified ? 'verified' : 'unverified'}}">
          <text class="verify-check">{{employerInfo.verified ? '✓' : '?'}}</text>
        </view>
        <view class="verify-info">
          <text class="verify-title">认证状态</text>
          <text class="verify-status-text {{employerInfo.verified ? 'verified-text' : 'unverified-text'}}">
            {{employerInfo.verified ? '已认证' : '未认证'}}
          </text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="section">
    <view class="menu-list">
      <view class="menu-item switch-worker" bindtap="onSwitchToWorker">
        <view class="menu-icon">
          <image class="menu-icon-img" src="/images/icons/share.svg" mode="aspectFit" />
        </view>
        <text class="menu-text">切回找工作</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" data-action="company" bindtap="onMenuItemTap">
        <view class="menu-icon">
          <image class="menu-icon-img" src="/images/icons/company.svg" mode="aspectFit" />
        </view>
        <text class="menu-text">企业信息</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" data-action="security" bindtap="onMenuItemTap">
        <view class="menu-icon">
          <image class="menu-icon-img" src="/images/icons/security.svg" mode="aspectFit" />
        </view>
        <text class="menu-text">账户安全</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" data-action="feedback" bindtap="onMenuItemTap">
        <view class="menu-icon">
          <image class="menu-icon-img" src="/images/icons/feedback.svg" mode="aspectFit" />
        </view>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" data-action="about" bindtap="onMenuItemTap">
        <view class="menu-icon">
          <image class="menu-icon-img" src="/images/icons/about.svg" mode="aspectFit" />
        </view>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" data-action="settings" bindtap="onMenuItemTap">
        <view class="menu-icon">
          <image class="menu-icon-img" src="/images/icons/settings.svg" mode="aspectFit" />
        </view>
        <text class="menu-text">设置</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version">
    <text class="version-text">找龄工 v1.0.0</text>
  </view>
</view>

<!-- 底部导航 -->
<employer-tabbar current="profile"></employer-tabbar>
