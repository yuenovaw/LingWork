.verify-page {
  min-height: 100vh;
  background: #F7FCF9;
  padding: 16px;
}

.page-title {
  display: block;
  font-size: 22px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 16px;
}

/* 已认证卡片 */
.verified-card {
  background: #D1FAE5;
  border-radius: 10px;
  padding: 40px 20px;
  text-align: center;
}

.verified-icon {
  display: block;
  font-size: 64px;
  color: #67BE86;
  margin-bottom: 16px;
}

.verified-title {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: #3f8b62;
  margin-bottom: 8px;
}

.verified-desc {
  display: block;
  font-size: 17px;
  color: #3f8b62;
}

/* 认证说明 */
.info-card {
  background: #FFFFFF;
  border-radius: 10px;
  padding: 16px;
  margin-bottom: 16px;
}

.info-title {
  display: block;
  font-size: 17px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 12px;
}

.info-text {
  display: block;
  font-size: 15px;
  color: #6B7280;
  margin-bottom: 8px;
}

.benefit-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.benefit-item {
  font-size: 15px;
  color: #1F2937;
  padding-left: 8px;
}

.upload-card {
  background: #FFFFFF;
  border-radius: 10px;
  padding: 16px;
  margin-bottom: 24px;
}

.upload-title {
  display: block;
  font-size: 17px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 12px;
}

.upload-area {
  border: 2px dashed #E5E7EB;
  border-radius: 10px;
  padding: 40px 20px;
  text-align: center;
}

.upload-icon {
  display: block;
  font-size: 48px;
  margin-bottom: 12px;
}

.upload-text {
  display: block;
  font-size: 15px;
  color: #9CA3AF;
}

.submit-btn {
  width: 100%;
  height: 48px;
  background: #67BE86;
  color: #FFFFFF;
  border-radius: 10px;
  font-size: 18px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  opacity: 0.8;
}
