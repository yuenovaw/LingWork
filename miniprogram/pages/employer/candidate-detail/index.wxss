/**
 * 候选人详情页
 */

.detail-page {
  min-height: 100vh;
  background: #F7FCF9;
  padding: 16px;
  padding-bottom: 100px;
}

/* 内容区域 */
.detail-content {
  /* 内容直接在页面级别，不需要额外容器 */
}

/* 候选人摘要卡片 */
.candidate-summary-card {
  background: #FFFFFF;
  border-radius: 10px;
  padding: 16px;
  margin-bottom: 16px;
}

.candidate-name-large {
  display: block;
  font-size: 20px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 4px;
}

.candidate-intention {
  display: block;
  font-size: 15px;
  color: #6B7280;
}

/* 信息区块 */
.info-section {
  margin-bottom: 20px;
}

.info-section-title {
  font-size: 17px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ai-badge {
  font-size: 13px;
  color: #2DD4BF;
  font-weight: normal;
}

.info-card {
  background: #FFFFFF;
  border-radius: 10px;
  padding: 16px;
}

.info-item {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #F3F4F6;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item-label {
  color: #6B7280;
  min-width: 80px;
  font-size: 15px;
}

.info-item-value {
  color: #1F2937;
  font-size: 15px;
  flex: 1;
}

/* 简历预览卡片 */
.resume-preview {
  background: linear-gradient(135deg, #F0FDFA, #E0F2FE);
  border-radius: 10px;
  padding: 20px;
  text-align: center;
}

.resume-preview:active {
  opacity: 0.8;
}

.resume-preview-icon {
  width: 60px;
  height: 60px;
  margin: 0 auto 16px;
  background: #FFFFFF;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.resume-svg {
  width: 32px;
  height: 32px;
}

.resume-title {
  display: block;
  font-size: 17px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8px;
}

.resume-desc {
  display: block;
  font-size: 14px;
  color: #6B7280;
  margin-bottom: 16px;
}

.resume-preview-btn {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background: #2DD4BF;
  color: white;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 500;
  text-align: center;
}

/* 联系方式区域 */
.contact-section {
  background: #FFFFFF;
  border-radius: 10px;
  padding: 16px;
  margin-bottom: 80px;
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
}

.contact-item-left {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
}

.contact-emoji {
  font-size: 20px;
}

.contact-label {
  font-size: 15px;
  color: #6B7280;
}

.contact-blur {
  color: #9CA3AF;
  font-size: 15px;
}

.contact-value {
  font-weight: 500;
  color: #1F2937;
  font-size: 15px;
}

.copy-btn {
  padding: 6px 12px;
  background: #F3F4F6;
  border-radius: 6px;
  font-size: 13px;
  color: #6B7280;
}

.copy-btn:active {
  background: #E5E7EB;
}

/* 安全提示 */
.safety-tip {
  text-align: center;
  padding: 16px 0;
}

.tip-text {
  font-size: 13px;
  color: #6B7280;
}

/* 底部操作按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 12px 16px;
  padding-bottom: calc(12px + constant(safe-area-inset-bottom));
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  border-top: 1px solid #E5E7EB;
  display: flex;
  gap: 12px;
}

.action-buttons {
  display: flex;
  gap: 12px;
  width: 100%;
}

.action-single {
  display: flex;
  justify-content: center;
  width: 100%;
}

.btn-large {
  flex: 1;
  height: 48px;
  border-radius: 10px;
  font-size: 18px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  background: #F3F4F6;
  color: #6B7280;
}

.btn-secondary:active {
  opacity: 0.8;
}

.btn-primary {
  background: #67BE86;
  color: white;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-success {
  background: #67BE86;
  color: white;
}

.btn-success:active {
  opacity: 0.8;
}

.status-tag {
  padding: 12px 32px;
  border-radius: 10px;
  font-size: 17px;
  font-weight: 500;
}

.hired-tag {
  background: #D1FAE5;
  color: #3f8b62;
}

.rejected-tag {
  background: #FEE2E2;
  color: #991B1B;
}
