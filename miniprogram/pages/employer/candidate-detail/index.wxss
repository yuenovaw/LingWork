/**
 * 候选人详情页
 */

.detail-page {
  min-height: 100vh;
  background: #F5FBF7;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* 候选人摘要卡片 */
.candidate-summary-card {
  background: linear-gradient(135deg, #065F46 0%, #10B981 60%, #34D399 100%);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 44rpx rgba(6, 95, 70, 0.38);
}

.candidate-name-large {
  display: block;
  font-size: 46rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 8rpx;
}

.candidate-intention {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.82);
}

/* 信息区块 */
.info-section {
  margin-bottom: 28rpx;
}

.info-section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  letter-spacing: 0.5rpx;
}

.ai-badge {
  font-size: 24rpx;
  color: #059669;
  font-weight: 700;
  background: #D1FAE5;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  border-left: 6rpx solid #10B981;
}

.info-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item-label {
  color: #6B7280;
  min-width: 120rpx;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.info-item-value {
  color: #111827;
  font-size: 30rpx;
  flex: 1;
  font-weight: 700;
}

/* 简历预览卡片 */
.resume-preview {
  background: linear-gradient(135deg, #ECFDF5, #DBEAFE);
  border-radius: 20rpx;
  padding: 36rpx;
  text-align: center;
  border: 2rpx solid #A7F3D0;
}

.resume-preview:active {
  opacity: 0.85;
}

.resume-preview-icon {
  width: 100rpx;
  height: 100rpx;
  margin: 0 auto 24rpx;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.resume-svg {
  width: 56rpx;
  height: 56rpx;
}

.resume-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 12rpx;
}

.resume-desc {
  display: block;
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 24rpx;
}

.resume-preview-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #065F46, #10B981);
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 6rpx 18rpx rgba(6, 95, 70, 0.35);
}

/* 联系方式区域 */
.contact-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  border-left: 6rpx solid #10B981;
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.contact-item-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
}

.contact-emoji {
  font-size: 36rpx;
}

.contact-label {
  font-size: 28rpx;
  color: #6B7280;
}

.contact-blur {
  color: #9CA3AF;
  font-size: 28rpx;
}

.contact-value {
  font-weight: 700;
  color: #111827;
  font-size: 30rpx;
}

.copy-btn {
  padding: 10rpx 20rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 600;
}

.copy-btn:active {
  background: #E5E7EB;
}

/* 安全提示 */
.safety-tip {
  text-align: center;
  padding: 16rpx 0;
}

.tip-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 底部操作按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.96);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #E5E7EB;
  display: flex;
  gap: 16rpx;
  backdrop-filter: blur(10px);
}

.action-buttons {
  display: flex;
  gap: 16rpx;
  width: 100%;
}

.action-single {
  display: flex;
  justify-content: center;
  width: 100%;
}

.btn-large {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  background: #F3F4F6;
  color: #6B7280;
}

.btn-secondary:active {
  opacity: 0.8;
}

.btn-primary {
  background: linear-gradient(135deg, #065F46, #10B981);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(6, 95, 70, 0.38);
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-success {
  background: linear-gradient(135deg, #065F46, #10B981);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(6, 95, 70, 0.38);
}

.btn-success:active {
  opacity: 0.85;
}

.status-tag {
  padding: 16rpx 48rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.hired-tag {
  background: #D1FAE5;
  color: #065F46;
}

.rejected-tag {
  background: #FEE2E2;
  color: #991B1B;
}
