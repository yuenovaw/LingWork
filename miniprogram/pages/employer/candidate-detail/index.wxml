<!--候选人详情页-->
<view class="detail-page">
  <!-- 候选人摘要 -->
    <view class="candidate-summary-card">
      <text class="candidate-name-large">{{candidateInfo.name}} · {{candidateInfo.age}}岁</text>
      <text class="candidate-intention">意向：{{candidateInfo.jobTitle}}</text>
    </view>

    <!-- 基本信息 -->
    <view class="info-section">
      <text class="info-section-title">基本信息</text>
      <view class="info-card">
        <view class="info-item">
          <text class="info-item-label">姓名</text>
          <text class="info-item-value">{{candidateInfo.name}}</text>
        </view>
        <view class="info-item">
          <text class="info-item-label">年龄</text>
          <text class="info-item-value">{{candidateInfo.age}}岁</text>
        </view>
        <view class="info-item">
          <text class="info-item-label">所在地</text>
          <text class="info-item-value">{{candidateInfo.location}}</text>
        </view>
        <view class="info-item">
          <text class="info-item-label">可上岗</text>
          <text class="info-item-value">{{candidateInfo.availableTime}}</text>
        </view>
      </view>
    </view>

    <!-- 个人简历 -->
    <view class="info-section">
      <view class="info-section-title">
        <text>个人简历</text>
        <text class="ai-badge">✨ AI 生成</text>
      </view>
      <view class="resume-preview" bindtap="onViewResume">
        <view class="resume-preview-icon">
          <image src="data:image/svg+xml;base64," class="resume-svg" mode="aspectFit"/>
        </view>
        <text class="resume-title">{{candidateInfo.name}}的简历</text>
        <text class="resume-desc">由 AI 帮助生成，包含完整工作经历和技能介绍</text>
        <view class="resume-preview-btn">查看完整简历 →</view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="info-section">
      <text class="info-section-title">联系方式</text>
      <view class="contact-section">
        <!-- 手机号 -->
        <view class="contact-item">
          <view class="contact-item-left">
            <text class="contact-emoji">📱</text>
            <text class="contact-label">手机号</text>
            <text wx:if="{{!showContact}}" class="contact-blur">匹配意向后可查看</text>
            <text wx:else class="contact-value">{{candidateInfo.phone}}</text>
          </view>
          <view wx:if="{{showContact}}" class="copy-btn" catchtap="onCopyPhone">复制</view>
        </view>

        <!-- 微信号 -->
        <view class="contact-item">
          <view class="contact-item-left">
            <text class="contact-emoji">💬</text>
            <text class="contact-label">微信号</text>
            <text wx:if="{{!showContact}}" class="contact-blur">匹配意向后可查看</text>
            <text wx:else class="contact-value">{{candidateInfo.wechat}}</text>
          </view>
          <view wx:if="{{showContact}}" class="copy-btn" catchtap="onCopyWechat">复制</view>
        </view>
      </view>
    </view>

    <!-- 安全提示 -->
    <view class="safety-tip">
      <text class="tip-text">{{tipText}}</text>
    </view>

  <!-- 底部操作按钮 -->
  <view class="bottom-actions">
    <!-- 待处理状态 -->
    <view wx:if="{{status === 'pending'}}" class="action-buttons">
      <view class="btn-large btn-secondary" bindtap="onNotSuitable">不合适</view>
      <view class="btn-large btn-primary" bindtap="onMatchInterest">匹配意向</view>
    </view>

    <!-- 沟通中状态 -->
    <view wx:if="{{status === 'communicating'}}" class="action-buttons">
      <view class="btn-large btn-secondary" bindtap="onNotSuitable">不合适</view>
      <view class="btn-large btn-success" bindtap="onHired">录用</view>
    </view>

    <!-- 已录用状态 -->
    <view wx:if="{{status === 'hired'}}" class="action-single">
      <view class="status-tag hired-tag">✓ 已录用</view>
    </view>

    <!-- 暂不合适状态 -->
    <view wx:if="{{status === 'rejected'}}" class="action-single">
      <view class="status-tag rejected-tag">× 不合适</view>
    </view>
  </view>
</view>
