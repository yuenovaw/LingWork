<view class="tabbar safe-area-bottom">
  <view
    wx:for="{{tabs}}"
    wx:key="key"
    class="tab {{current === item.key ? 'active' : ''}}"
    data-key="{{item.key}}"
    bindtap="onTabTap"
  >
    <view class="icon">{{item.icon}}</view>
    <view class="label">{{item.label}}</view>
  </view>
</view>
