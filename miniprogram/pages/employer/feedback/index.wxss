.feedback-page {
  min-height: 100vh;
  background: #F5FBF7;
  padding: 32rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #111827;
  margin-bottom: 28rpx;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  border-left: 6rpx solid #10B981;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 18rpx;
}

.type-selector {
  display: flex;
  gap: 14rpx;
}

.type-option {
  flex: 1;
  height: 72rpx;
  background: #F3F4F6;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
}

.type-option.active {
  background: #D1FAE5;
  border-color: #10B981;
}

.type-option:active {
  opacity: 0.8;
}

.type-text {
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 600;
}

.type-option.active .type-text {
  color: #065F46;
  font-weight: 800;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  font-size: 30rpx;
  background: #F9FAF9;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
  box-sizing: border-box;
  color: #111827;
  line-height: 1.6;
}

.form-textarea:focus {
  border-color: #10B981;
  background: #fff;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #065F46, #10B981);
  color: #fff;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
  box-shadow: 0 10rpx 28rpx rgba(6, 95, 70, 0.38);
  letter-spacing: 2rpx;
}

.submit-btn:active {
  opacity: 0.85;
}
