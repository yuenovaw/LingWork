.feedback-page {
  min-height: 100vh;
  background: #F7FCF9;
  padding: 16px;
}

.page-title {
  display: block;
  font-size: 22px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 16px;
}

.form-card {
  background: #FFFFFF;
  border-radius: 10px;
  padding: 16px;
}

.form-item {
  margin-bottom: 20px;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 17px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 12px;
}

.type-selector {
  display: flex;
  gap: 8px;
}

.type-option {
  flex: 1;
  height: 40px;
  background: #F3F4F6;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid transparent;
  transition: all 0.2s;
}

.type-option.active {
  background: #F7FCF9;
  border-color: #67BE86;
}

.type-option:active {
  opacity: 0.8;
}

.type-text {
  font-size: 15px;
  color: #6B7280;
}

.type-option.active .type-text {
  color: #67BE86;
  font-weight: 500;
}

.form-textarea {
  width: 100%;
  min-height: 120px;
  padding: 12px;
  font-size: 17px;
  background: #F3F4F6;
  border-radius: 8px;
  border: 2px solid transparent;
  transition: all 0.2s;
}

.form-textarea:focus {
  border-color: #67BE86;
  background: #FFFFFF;
}

.submit-btn {
  width: 100%;
  height: 48px;
  background: #67BE86;
  color: #FFFFFF;
  border-radius: 10px;
  font-size: 18px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8px;
}

.submit-btn:active {
  opacity: 0.8;
}
