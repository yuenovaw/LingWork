/**
 * 职位页
 */

.jobs-page {
  min-height: 100vh;
  background: #F5FBF7;
  padding: 32rpx;
}

/* 筛选标签 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.07);
  gap: 8rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  font-size: 28rpx;
  color: #9CA3AF;
  border-radius: 14rpx;
  font-weight: 600;
}

.tab.active {
  background: linear-gradient(135deg, #065F46, #10B981);
  color: #fff;
  font-weight: 800;
  box-shadow: 0 4rpx 14rpx rgba(6, 95, 70, 0.35);
}

/* 岗位列表 */
.job-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.job-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  border-left: 6rpx solid #10B981;
}

.job-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.job-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.status-active {
  background: #D1FAE5;
  color: #065F46;
}

.status-closed {
  background: #F3F4F6;
  color: #9CA3AF;
}

.job-closed {
  border-left-color: #D1D5DB;
  opacity: 0.85;
}

/* 岗位详情 */
.job-details {
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 12rpx;
}

.detail-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 30rpx;
  color: #374151;
  font-weight: 600;
}

/* 底部操作 */
.job-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid #F3F4F6;
}

.job-pending {
  font-size: 28rpx;
  color: #9CA3AF;
}

.action-buttons {
  display: flex;
  gap: 14rpx;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.edit-btn {
  background: #F3F4F6;
  color: #374151;
}

.close-btn {
  background: #FEE2E2;
  color: #DC2626;
}

.restore-btn {
  background: #D1FAE5;
  color: #065F46;
}

/* 加载中 */
.loading-state {
  padding: 80rpx 32rpx;
  text-align: center;
}

.loading-text {
  font-size: 30rpx;
  color: #9CA3AF;
}

/* 空状态 */
.empty-state {
  background: #fff;
  border-radius: 20rpx;
  padding: 80rpx 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.06);
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #374151;
  margin-bottom: 12rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #9CA3AF;
  line-height: 1.6;
}
