<!--消息页-->
<view class="messages-page page-with-tabbar">
  <!-- 状态标签 -->
  <view class="tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab {{activeTab === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabTap"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 候选人列表 -->
  <view class="candidate-list">
    <view
      wx:for="{{filteredCandidates}}"
      wx:key="id"
      class="candidate-card"
      data-id="{{item.id}}"
      bindtap="onCandidateTap"
    >
      <view class="candidate-avatar">{{item.name.slice(0,1)}}</view>
      <view class="candidate-body">
        <view class="candidate-header">
          <text class="candidate-name">{{item.name}}</text>
          <text class="candidate-age">{{item.age}}岁</text>
        </view>
        <text class="candidate-meta">{{item.jobTitle || '求职者'}}</text>
        <text class="candidate-intro">{{item.summary}}</text>
        <view class="candidate-footer">
          <text class="candidate-time">{{item.time}}</text>
          <text class="candidate-cta">查看详情 ›</text>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading-state">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{filteredCandidates.length === 0}}" class="empty-state">
      <text class="empty-title">暂无候选人</text>
      <text class="empty-text">求职者报名后会出现在这里</text>
    </view>
  </view>
</view>

<!-- 底部导航 -->
<employer-tabbar current="messages"></employer-tabbar>
