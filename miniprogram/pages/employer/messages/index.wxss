/**
 * 消息页
 */

.messages-page {
  min-height: 100vh;
  background: #F5FBF7;
}

/* 状态标签 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin: 28rpx 28rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.07);
  position: sticky;
  top: 0;
  z-index: 10;
  gap: 8rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 10rpx;
  font-size: 26rpx;
  color: #9CA3AF;
  border-radius: 14rpx;
  font-weight: 600;
}

.tab.active {
  background: linear-gradient(135deg, #065F46, #10B981);
  color: #fff;
  font-weight: 800;
  box-shadow: 0 4rpx 14rpx rgba(6, 95, 70, 0.35);
}

/* 候选人列表 */
.candidate-list {
  padding: 20rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.candidate-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  border-left: 6rpx solid #10B981;
  transition: background-color 0.15s;
}

.candidate-card:active {
  background-color: #F0FDF4;
}

/* 头像圆圈 */
.candidate-avatar {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #065F46, #10B981);
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
  flex-shrink: 0;
}

.candidate-body {
  flex: 1;
  min-width: 0;
}

.candidate-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.candidate-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
}

.candidate-age {
  font-size: 26rpx;
  color: #9CA3AF;
}

.candidate-meta {
  display: block;
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.candidate-intro {
  display: block;
  font-size: 28rpx;
  color: #9CA3AF;
  line-height: 1.5;
  margin-bottom: 14rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.candidate-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.candidate-time {
  font-size: 26rpx;
  color: #D1D5DB;
}

.candidate-cta {
  font-size: 26rpx;
  color: #059669;
  font-weight: 700;
  background: #D1FAE5;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}

/* 加载中 */
.loading-state {
  padding: 80rpx 28rpx;
  text-align: center;
}

.loading-text {
  font-size: 30rpx;
  color: #9CA3AF;
}

/* 空状态 */
.empty-state {
  background: #fff;
  border-radius: 20rpx;
  padding: 80rpx 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.06);
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #374151;
  margin-bottom: 12rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #9CA3AF;
}
