/**
 * 首页
 */

.home-page {
  padding: 32rpx;
  min-height: 100vh;
  background: #F5FBF7;
}

/* 雇主信息横幅 */
.employer-card {
  background: linear-gradient(135deg, #065F46 0%, #10B981 60%, #34D399 100%);
  border-radius: 28rpx;
  padding: 36rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 44rpx rgba(6, 95, 70, 0.38);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50%;
  text-align: center;
  background: rgba(255, 255, 255, 0.22);
  color: #fff;
  font-size: 40rpx;
  font-weight: 900;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.38);
}

.employer-info {
  flex: 1;
}

.employer-name {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 8rpx;
}

.employer-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.employer-type {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.78);
}

.verified-badge {
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 700;
}

.unverified-badge {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
  font-weight: 600;
}

.arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.65);
}

/* 区块 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-action {
  font-size: 30rpx;
  color: #059669;
  font-weight: 700;
  background: #D1FAE5;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 8rpx;
  min-height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  border-top: 4rpx solid transparent;
}

.stat-card:active {
  background-color: #f9fafb;
}

.stat-card:nth-child(1) { border-top-color: #059669; }
.stat-card:nth-child(2) { border-top-color: #F59E0B; }
.stat-card:nth-child(3) { border-top-color: #3B82F6; }
.stat-card:nth-child(4) { border-top-color: #8B5CF6; }

.stat-value {
  display: block;
  font-size: 52rpx;
  font-weight: 900;
  margin-bottom: 6rpx;
}

.stat-card:nth-child(1) .stat-value { color: #059669; }
.stat-card:nth-child(2) .stat-value { color: #D97706; }
.stat-card:nth-child(3) .stat-value { color: #2563EB; }
.stat-card:nth-child(4) .stat-value { color: #7C3AED; }

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 2rpx;
  font-weight: 600;
}

.stat-loading {
  color: #D1D5DB !important;
}

/* 岗位列表 */
.job-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty-state {
  background: #fff;
  border-radius: 20rpx;
  padding: 52rpx 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.06);
}

.empty-text {
  font-size: 30rpx;
  color: #9CA3AF;
}

.job-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  border-left: 6rpx solid #10B981;
}

.job-card:active {
  background-color: #f9fafb;
}

.job-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.job-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.status-active {
  background: #D1FAE5;
  color: #065F46;
}

.status-closed {
  background: #F3F4F6;
  color: #6B7280;
}

.job-info {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.job-salary {
  font-size: 44rpx;
  font-weight: 900;
  color: #065F46;
}

.job-location {
  font-size: 28rpx;
  color: #6B7280;
}

.job-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid #F3F4F6;
}

.job-pending {
  font-size: 28rpx;
  color: #9CA3AF;
}

.job-action {
  font-size: 28rpx;
  color: #059669;
  font-weight: 700;
  padding: 8rpx 24rpx;
  background: #D1FAE5;
  border-radius: 999rpx;
}

.job-action:active {
  background-color: #A7F3D0;
}
