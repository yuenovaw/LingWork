<!--首页-->
<view class="home-page page-with-tabbar">
  <!-- 雇主信息卡片 -->
  <view class="employer-card" bindtap="onEmployerCardTap">
    <view class="avatar avatar-text">{{employerInfo.name.slice(0, 1)}}</view>
    <view class="employer-info">
      <text class="employer-name">{{employerInfo.name}}</text>
      <view class="employer-meta">
        <text class="employer-type">{{employerInfo.type}}</text>
        <text class="verified-badge" wx:if="{{employerInfo.verified}}">✓ 已认证</text>
        <text class="unverified-badge" wx:else>未认证</text>
      </view>
    </view>
    <view class="arrow">›</view>
  </view>

  <!-- 招聘概况 -->
  <view class="section">
    <text class="section-title">招聘概况</text>
    <view class="stats-grid">
      <view class="stat-card" data-type="active" bindtap="onStatTap">
        <text class="stat-value">{{stats.activeJobs}}</text>
        <text class="stat-label">在招职位</text>
      </view>
      <view class="stat-card" data-type="pending" bindtap="onStatTap">
        <text class="stat-value">{{stats.pending}}</text>
        <text class="stat-label">待处理</text>
      </view>
      <view class="stat-card" data-type="communicating" bindtap="onStatTap">
        <text class="stat-value">{{stats.communicating}}</text>
        <text class="stat-label">沟通中</text>
      </view>
      <view class="stat-card" data-type="hired" bindtap="onStatTap">
        <text class="stat-value">{{stats.hired}}</text>
        <text class="stat-label">已录用</text>
      </view>
    </view>
  </view>

  <!-- 最近招聘 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">最近招聘</text>
      <text class="section-action" bindtap="onAddJob">+ 发布</text>
    </view>

    <view class="job-list">
      <view
        wx:for="{{recentJobs}}"
        wx:key="id"
        class="job-card"
        data-id="{{item.id}}"
        bindtap="onJobTap"
      >
        <view class="job-header">
          <text class="job-title">{{item.title}}</text>
          <view class="status-badge status-active">招聘中</view>
        </view>
        <view class="job-info">
          <text class="job-salary">{{item.salary}}</text>
          <text class="job-location">· {{item.location}}</text>
        </view>
        <view class="job-footer">
          <text class="job-pending">待处理 {{item.pendingCount}} 人</text>
          <view class="job-action" catchtap="onViewApplicants" data-id="{{item.id}}">
            <text>查看 ›</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 底部导航 -->
<employer-tabbar current="home"></employer-tabbar>
