/**
 * 发布岗位表单页
 */

.publish-form-page {
  min-height: 100vh;
  background: #F5FBF7;
  padding-bottom: 140rpx;
}

/* 表单主体 */
.form-body {
  height: 100vh;
  padding: 32rpx;
  padding-bottom: 140rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
  border-left: 6rpx solid #10B981;
}

.form-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #059669;
  margin-bottom: 4rpx;
  padding: 16rpx 28rpx 0;
  letter-spacing: 0.5rpx;
}

.form-item {
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.label.required::before {
  content: '*';
  color: #EF4444;
  margin-right: 6rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  color: #111827;
  font-weight: 600;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 30rpx;
  color: #111827;
  padding: 8rpx 0;
  line-height: 1.6;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

/* 底部提交栏 */
.form-submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.96);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #E5E7EB;
  backdrop-filter: blur(10px);
}

.form-submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #065F46, #10B981);
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 28rpx rgba(6, 95, 70, 0.38);
  letter-spacing: 2rpx;
}

.form-submit-btn:active {
  opacity: 0.85;
}
