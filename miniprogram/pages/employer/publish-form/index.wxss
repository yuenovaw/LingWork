/**
 * 发布岗位表单页
 */

.publish-form-page {
  min-height: 100vh;
  background: #F7FCF9;
  padding-bottom: 80px;
}

/* 表单主体 */
.form-body {
  height: 100vh;
  padding: 16px;
  padding-bottom: 80px;
  overflow-y: auto;
}

.form-section {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 8px 0;
  margin-bottom: 16px;
}

.form-section-title {
  display: block;
  font-size: 17px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8px;
  padding: 8px 16px 0;
}

.form-item {
  padding: 16px;
  border-bottom: 1px solid #F3F4F6;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 17px;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 12px;
}

.label.required::before {
  content: '*';
  color: #EF4444;
  margin-right: 4px;
}

.input {
  width: 100%;
  height: 48px;
  font-size: 17px;
  color: #1F2937;
}

.textarea {
  width: 100%;
  min-height: 120px;
  font-size: 17px;
  color: #1F2937;
  padding: 8px 0;
}

.form-hint {
  display: block;
  font-size: 14px;
  color: #9CA3AF;
  margin-top: 4px;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 14px;
  color: #9CA3AF;
  margin-top: 4px;
}

/* 底部提交栏 */
.form-submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 12px 16px;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1px solid #E5E7EB;
}

.form-submit-btn {
  width: 100%;
  height: 52px;
  background: #67BE86;
  color: #FFFFFF;
  border: none;
  border-radius: 10px;
  font-size: 18px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.form-submit-btn:active {
  background: #E57332;
}
