.about-page {
  min-height: 100vh;
  background: #F5FBF7;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.logo-section {
  text-align: center;
  padding: 32rpx 0 40rpx;
  background: linear-gradient(135deg, #065F46 0%, #10B981 60%, #34D399 100%);
  border-radius: 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 44rpx rgba(6, 95, 70, 0.38);
}

.app-logo {
  display: block;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 28rpx;
  border-radius: 44rpx;
  box-shadow: 0 10rpx 32rpx rgba(0, 0, 0, 0.2);
}

.app-name {
  display: block;
  font-size: 46rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
}

.app-version {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.78);
}

.info-text {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.07);
  border-left: 6rpx solid #10B981;
}

.text-block {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

.link-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.07);
}

.link-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.link-item:last-child {
  border-bottom: none;
}

.link-item:active {
  background: #F0FDF4;
}

.link-text {
  font-size: 32rpx;
  color: #111827;
  font-weight: 600;
}

.link-arrow {
  font-size: 30rpx;
  color: #D1D5DB;
}

.copyright {
  margin-top: auto;
  padding: 28rpx 0;
  text-align: center;
}

.copyright-text {
  font-size: 26rpx;
  color: #9CA3AF;
}
