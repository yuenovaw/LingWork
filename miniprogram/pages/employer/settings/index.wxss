.settings-page {
  min-height: 100vh;
  background: #F7FCF9;
  padding: 16px;
}

.page-title {
  display: block;
  font-size: 22px;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 16px;
}

.settings-list {
  background: #FFFFFF;
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 24px;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #F3F4F6;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: rgba(0, 0, 0, 0.03);
}

.setting-label {
  font-size: 17px;
  color: #1F2937;
}

.setting-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.setting-value {
  font-size: 15px;
  color: #9CA3AF;
}

.setting-arrow {
  font-size: 15px;
  color: #9CA3AF;
}

.logout-btn {
  width: 100%;
  height: 48px;
  background: #FFFFFF;
  border: 1px solid #E5E7EB;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn:active {
  background: #F9FAFB;
}

.logout-text {
  font-size: 17px;
  color: #EF4444;
  font-weight: 500;
}
