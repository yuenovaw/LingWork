.settings-page {
  min-height: 100vh;
  background: #F5FBF7;
  padding: 32rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #111827;
  margin-bottom: 28rpx;
}

.settings-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  background: #F0FDF4;
}

.setting-label {
  font-size: 32rpx;
  color: #111827;
  font-weight: 600;
}

.setting-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.setting-value {
  font-size: 28rpx;
  color: #9CA3AF;
}

.setting-arrow {
  font-size: 30rpx;
  color: #D1D5DB;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border: 2rpx solid #FCA5A5;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.06);
}

.logout-btn:active {
  background: #FEF2F2;
}

.logout-text {
  font-size: 32rpx;
  color: #EF4444;
  font-weight: 700;
}
