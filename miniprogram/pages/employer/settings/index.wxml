<!--设置页面-->
<view class="settings-page">
  <text class="page-title">设置</text>

  <view class="settings-list">
    <view class="setting-item" bindtap="onClearCache">
      <text class="setting-label">清除缓存</text>
      <view class="setting-right">
        <text class="setting-value">12.5MB</text>
        <text class="setting-arrow">→</text>
      </view>
    </view>

    <view class="setting-item" bindtap="onCheckUpdate">
      <text class="setting-label">检查更新</text>
      <view class="setting-right">
        <text class="setting-value">当前版本 v1.0.0</text>
        <text class="setting-arrow">→</text>
      </view>
    </view>

    <view class="setting-item" bindtap="onContact">
      <text class="setting-label">联系客服</text>
      <text class="setting-arrow">→</text>
    </view>
  </view>

  <view class="logout-btn" bindtap="onLogout">
    <text class="logout-text">退出登录</text>
  </view>
</view>
