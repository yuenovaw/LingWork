page {
  background: #f7fcf9;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
  box-sizing: border-box;
}

.voice-page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  overflow: hidden;
  color: #24362c;
  background:
    radial-gradient(circle at 50% 30%, rgba(255, 255, 255, 0.96), transparent 34%),
    linear-gradient(180deg, #f7fcf9 0%, #eff9f3 100%);
  display: flex;
  flex-direction: column;
}

.topbar {
  height: 116rpx;
  padding: 30rpx 36rpx 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.top-icon,
.text-mode {
  width: 68rpx;
  height: 68rpx;
  min-width: 68rpx;
  max-width: 68rpx;
  flex: 0 0 68rpx;
  border-radius: 50%;
  color: #24362c;
  font-size: 46rpx;
  font-weight: 800;
  background: #fff;
  border: 2rpx solid #e3f1e8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.text-mode {
  font-size: 38rpx;
  font-weight: 900;
}

.scene-pill {
  width: 286rpx;
  min-width: 286rpx;
  height: 70rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #3f8b62;
  font-size: 30rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border: 2rpx solid #e3f1e8;
  box-shadow: none;
  flex: 0 0 auto;
}

.scene-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  background: #67be86;
}

.stage {
  position: relative;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 14rpx 28rpx 8rpx;
  box-sizing: border-box;
}

.assistant-orb-wrap {
  position: relative;
  width: 330rpx;
  height: 330rpx;
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  opacity: 1;
}

.assistant-orb {
  position: relative;
  width: 270rpx;
  height: 270rpx;
  border-radius: 50%;
  overflow: hidden;
  background: transparent;
  border: 0;
  box-shadow:
    0 24rpx 62rpx rgba(84, 158, 116, 0.16),
    inset 0 6rpx 24rpx rgba(255, 255, 255, 0.36),
    inset 0 -24rpx 54rpx rgba(168, 214, 192, 0.18);
  transform: none;
  animation: glassBreathe 6.5s ease-in-out infinite;
}

.orb-canvas {
  display: block;
  width: 270rpx;
  height: 270rpx;
  pointer-events: none;
}

.orb-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(122, 214, 158, 0.34);
  opacity: 0;
}

.ring-one {
  width: 286rpx;
  height: 286rpx;
}

.ring-two {
  width: 330rpx;
  height: 330rpx;
}

.stage.active .ring-one {
  animation: ringPulse 1.7s ease-out infinite;
}

.stage.active .ring-two {
  animation: ringPulse 1.7s ease-out 0.35s infinite;
}

.stage.recording .assistant-orb,
.stage.speaking .assistant-orb {
  animation: orbListen 1.45s ease-in-out infinite, glassBreathe 3.2s ease-in-out infinite;
}


.main-status {
  position: relative;
  z-index: 5;
  margin-top: 0;
  color: #24362c;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.25;
  text-align: center;
}

.sub-status {
  position: relative;
  z-index: 5;
  margin-top: 8rpx;
  color: #7b7069;
  font-size: 27rpx;
  font-weight: 800;
  text-align: center;
}

.status-dots {
  position: relative;
  z-index: 5;
  height: 32rpx;
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.status-dots view {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(103, 190, 134, 0.22);
}

.status-dots.active view {
  background: rgba(103, 190, 134, 0.5);
  animation: dotBounce 1.1s ease-in-out infinite;
}

.status-dots.active view:nth-child(2) {
  animation-delay: 0.15s;
}

.status-dots.active view:nth-child(3) {
  animation-delay: 0.3s;
}

.status-dots.active view:nth-child(4) {
  animation-delay: 0.45s;
}

.dialog-zone {
  position: relative;
  width: 100%;
  height: 286rpx;
  margin: 0 0 8rpx;
  z-index: 4;
  pointer-events: auto;
}

.transcript-card {
  height: 286rpx;
  flex-shrink: 0;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid #e3f1e8;
  pointer-events: auto;
  touch-action: pan-y;
}

.transcript-inner {
  min-height: 286rpx;
  padding: 18rpx 18rpx 26rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.line {
  display: flex;
  align-items: flex-start;
  margin: 10rpx 0;
  opacity: 0.56;
  transform: scale(0.98);
  transform-origin: left center;
  padding-right: 84rpx;
  box-sizing: border-box;
}

.line.user {
  justify-content: flex-end;
  transform-origin: right center;
  padding-right: 0;
  padding-left: 84rpx;
}

.line-text {
  max-width: 440rpx;
  padding: 16rpx 20rpx;
  border-radius: 30rpx;
  border-bottom-left-radius: 10rpx;
  background: #fff;
  color: #24362c;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.38;
  box-shadow: 0 8rpx 20rpx rgba(79, 139, 97, 0.06);
  word-break: break-word;
}

.line.user .line-text {
  color: #fff;
  background: rgba(103, 190, 134, 0.78);
  border-bottom-left-radius: 30rpx;
  border-bottom-right-radius: 10rpx;
}

.thinking-line .line-text {
  color: #6f655d;
  background: rgba(255, 255, 255, 0.54);
}

.line:nth-last-child(5) {
  opacity: 0.28;
  transform: scale(0.96);
}

.line:nth-last-child(4) {
  opacity: 0.48;
  transform: scale(0.97);
}

.line:nth-last-child(3) {
  opacity: 0.68;
  transform: scale(0.985);
}

.line:nth-last-child(2) {
  opacity: 1;
  transform: scale(1);
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.line:nth-last-child(2) .line-text {
  max-width: 540rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 30rpx rgba(79, 139, 97, 0.1);
}

.line.user:nth-last-child(2) .line-text {
  max-width: 460rpx;
  background: rgba(103, 190, 134, 0.9);
}

.transcript-anchor {
  height: 18rpx;
}

.quick-zone {
  margin: 0 34rpx 10rpx;
  flex-shrink: 0;
}

.quick-say {
  margin: 2rpx auto 0;
  width: 620rpx;
  max-width: 100%;
  padding: 12rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(241, 250, 244, 0.88);
  border: 2rpx solid #e3f1e8;
  box-sizing: border-box;
}

.quick-title,
.quick-text {
  display: block;
  font-size: 25rpx;
  line-height: 1.38;
  font-weight: 900;
}

.quick-title {
  color: #7b7069;
}

.quick-text {
  margin-top: 8rpx;
  color: #3f8b62;
}

.summary-panel {
  height: 48vh;
  margin: 0 30rpx 22rpx;
  flex-shrink: 0;
  border-radius: 34rpx;
  background: #fff;
  border: 2rpx solid #e3f1e8;
  box-shadow: 0 16rpx 36rpx rgba(79, 139, 97, 0.08);
}

.summary {
  padding: 28rpx;
}

.summary-title {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.25;
}

.summary-subtitle {
  margin-top: 8rpx;
  color: #7b7069;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 800;
}

.summary-list {
  padding-top: 14rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #e1eee6;
  font-size: 30rpx;
  line-height: 1.45;
}

.summary-row text:first-child {
  color: #7b7069;
  flex-shrink: 0;
  font-weight: 800;
}

.summary-row text:last-child {
  color: #302923;
  text-align: right;
  font-weight: 900;
}

.resume {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f1faf4;
  color: #3f8b62;
  font-size: 30rpx;
  line-height: 1.65;
  font-weight: 800;
}

.safe-note {
  margin-top: 18rpx;
  color: #7b7069;
  font-size: 27rpx;
  line-height: 1.5;
  font-weight: 800;
}

.summary-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.summary-actions button {
  flex: 1;
  height: 88rpx;
  border-radius: 28rpx;
  background: #f7fcf9;
  color: #4f463d;
  border: 2rpx solid #e3f1e8;
  font-size: 30rpx;
  font-weight: 900;
}

.summary-actions .primary {
  background: #67be86;
  color: #fff;
  border-color: #67be86;
}

.bottom-panel {
  padding: 10rpx 38rpx calc(22rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(244, 251, 246, 0), rgba(244, 251, 246, 0.88) 28%, #f7fcf9);
  flex-shrink: 0;
}

.keyboard-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 92rpx;
  margin: 0 0 16rpx;
  padding: 9rpx 10rpx 9rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid #e3f1e8;
  box-shadow: 0 14rpx 34rpx rgba(79, 139, 97, 0.08);
  box-sizing: border-box;
}

.keyboard-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 18rpx;
  background: #eef9f2;
  color: #3f8b62;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
  flex: 0 0 48rpx;
}

.text-input {
  flex: 1;
  height: 68rpx;
  min-width: 0;
  padding: 0 8rpx;
  border-radius: 0;
  background: transparent;
  color: #302923;
  border: 0;
  font-size: 29rpx;
  font-weight: 900;
}

.send-btn {
  width: 116rpx;
  height: 70rpx;
  min-width: 116rpx;
  max-width: 116rpx;
  flex: 0 0 116rpx;
  border-radius: 999rpx;
  background: #67be86;
  color: #fff;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 20rpx rgba(103, 190, 134, 0.18);
}

.helper-text {
  min-height: 42rpx;
  color: rgba(80, 70, 62, 0.78);
  font-size: 28rpx;
  line-height: 1.4;
  text-align: center;
  font-weight: 900;
}

.control-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 34rpx;
}

.round-btn {
  width: 132rpx;
  height: 132rpx;
  min-width: 132rpx;
  max-width: 132rpx;
  flex: 0 0 132rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.82);
  color: #302923;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 2rpx solid #e3f1e8;
  box-shadow: 0 14rpx 32rpx rgba(79, 139, 97, 0.07);
}

.round-icon {
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 18rpx;
  background: #eef9f2;
  color: #3f8b62;
  text-align: center;
  font-size: 27rpx;
}

.talk-btn {
  width: 190rpx;
  height: 190rpx;
  min-width: 190rpx;
  max-width: 190rpx;
  border-radius: 50%;
  background: #67be86;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  flex: 0 0 190rpx;
  box-shadow: 0 22rpx 44rpx rgba(103, 190, 134, 0.24);
}

.talk-btn.recording {
  background: linear-gradient(180deg, #7ed69c, #4aa76e);
  box-shadow: 0 24rpx 42rpx rgba(74, 167, 110, 0.28);
}

.keyboard-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
}

.keyboard-tip {
  color: rgba(80, 70, 62, 0.62);
  font-size: 25rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.keyboard-mode-btn {
  min-width: 230rpx;
  height: 78rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #4f453b;
  font-size: 29rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border: 2rpx solid #e3f1e8;
  box-shadow: 0 14rpx 30rpx rgba(79, 139, 97, 0.07);
}

.keyboard-mode-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 18rpx;
  background: #eef9f2;
  color: #3f8b62;
  font-size: 24rpx;
  text-align: center;
}

.mic-mark {
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #fff;
  font-size: 27rpx;
  text-align: center;
  font-weight: 900;
}

.hangup-btn {
  display: block;
  width: auto;
  height: 56rpx;
  margin: 10rpx auto 0;
  padding: 0 24rpx;
  color: rgba(80, 70, 62, 0.62);
  font-size: 26rpx;
  font-weight: 900;
}

@keyframes glassBreathe {
  0%, 100% {
    box-shadow:
      0 24rpx 62rpx rgba(84, 158, 116, 0.16),
      inset 0 6rpx 24rpx rgba(255, 255, 255, 0.36),
      inset 0 -24rpx 54rpx rgba(168, 214, 192, 0.18);
  }
  50% {
    box-shadow:
      0 30rpx 78rpx rgba(90, 200, 132, 0.2),
      inset 0 7rpx 28rpx rgba(255, 255, 255, 0.42),
      inset 0 -28rpx 64rpx rgba(172, 226, 198, 0.22);
  }
}

@keyframes orbListen {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.92;
  }
}

@keyframes ringPulse {
  0% {
    opacity: 0.38;
    transform: scale(0.96);
  }
  100% {
    opacity: 0;
    transform: scale(1.04);
  }
}

@keyframes dotBounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}
