page {
  background: #F5F7FF;
}

button {
  margin: 0; padding: 0; border: 0;
  background: transparent; line-height: 1; box-sizing: border-box;
}

/* ── Page ── */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #EEF2FF 0%, #F5F7FF 100%);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* ── Top Nav ── */
.topnav {
  display: flex;
  align-items: center;
  height: 104rpx;
  padding: 0 24rpx;
  flex-shrink: 0;
}

.nav-close {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #E0E7FF;
  color: #3B82F6;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-mid {
  flex: 1;
  text-align: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E40AF;
}

.nav-badge {
  min-width: 84rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #DBEAFE;
  color: #1E40AF;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── Select Screen ── */
.select-screen {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 36rpx;
}

.select-lead {
  font-size: 38rpx;
  font-weight: 700;
  color: #1E3A8A;
  text-align: center;
  margin-bottom: 48rpx;
}

.select-cards {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.select-card {
  background: #fff;
  border-radius: 20rpx;
  border: 3rpx solid #BFDBFE;
  padding: 36rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(37, 99, 235, 0.1);
}

.select-card:active {
  background: #EFF6FF;
  border-color: #3B82F6;
}

.card-icon {
  font-size: 64rpx;
}

.card-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1E40AF;
}

.card-desc {
  font-size: 28rpx;
  color: #6B7280;
}

.select-skip {
  color: #9CA3AF;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 12rpx;
}

/* ── Chat ── */
.chat {
  flex: 1;
  min-height: 0;
  padding: 12rpx 24rpx 0;
}

.chat-inner {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 16rpx;
}

.row {
  display: flex;
}

.row-left { justify-content: flex-start; }
.row-right { justify-content: flex-end; }

.bubble {
  max-width: 72%;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.55;
  word-break: break-word;
}

.bubble-ai {
  background: #fff;
  color: #1E3A8A;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(37, 99, 235, 0.08);
}

.bubble-user {
  background: linear-gradient(135deg, #2563EB, #3B82F6);
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.bubble-text { display: block; }

.bubble-typing {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 28rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #3B82F6;
  animation: dotBounce 1.1s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.18s; }
.dot:nth-child(3) { animation-delay: 0.36s; }

/* ── Summary ── */
.summary-scroll { flex: 1; min-height: 0; }

.summary { padding: 32rpx 36rpx; }

.summary-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1E40AF;
  margin-bottom: 8rpx;
}

.summary-sub {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 28rpx;
}

.summary-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #DBEAFE;
  margin-bottom: 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 28rpx;
  border-bottom: 2rpx solid #EFF6FF;
  font-size: 30rpx;
  gap: 24rpx;
}

.summary-row:last-child { border-bottom: none; }

.summary-row text:first-child {
  color: #6B7280;
  flex-shrink: 0;
  font-weight: 600;
}

.summary-row text:last-child {
  color: #1E3A8A;
  font-weight: 700;
  text-align: right;
}

.resume-box {
  background: #EFF6FF;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1E40AF;
  line-height: 1.65;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.safe-note {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 28rpx;
  text-align: center;
}

.summary-btns {
  display: flex;
  gap: 16rpx;
}

.summary-btns button {
  flex: 1;
  height: 90rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  background: #fff;
  color: #374151;
  border: 2rpx solid #DBEAFE;
}

.btn-go {
  background: linear-gradient(135deg, #1E40AF, #3B82F6) !important;
  color: #fff !important;
  border-color: transparent !important;
}

/* ── Orb Stage ── */
.orb-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 14rpx 0 18rpx;
  flex-shrink: 0;
}

.orb-glow-ring {
  position: absolute;
  width: 390rpx;
  height: 390rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(110, 80, 255, 0.18) 0%, rgba(110, 80, 255, 0) 68%);
  pointer-events: none;
  transition: background 0.5s;
}

.orb-glow-ring.glow-rec {
  background: radial-gradient(circle, rgba(255, 70, 20, 0.38) 0%, rgba(255, 70, 20, 0) 68%);
  animation: glowPulse 0.75s ease-in-out infinite;
}

.orb-glow-ring.glow-speak {
  background: radial-gradient(circle, rgba(110, 80, 255, 0.42) 0%, rgba(110, 80, 255, 0) 68%);
  animation: glowPulse 1.4s ease-in-out infinite;
}

.orb-glow-ring.glow-think {
  background: radial-gradient(circle, rgba(0, 200, 230, 0.3) 0%, rgba(0, 200, 230, 0) 68%);
  animation: glowPulse 2.2s ease-in-out infinite;
}

.orb-wrap {
  width: 290rpx;
  height: 290rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #FAFBFF;
  box-shadow:
    0 0 56rpx rgba(120, 100, 255, 0.22),
    0 18rpx 52rpx rgba(80, 80, 200, 0.16),
    inset 0 4rpx 16rpx rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.orb-canvas {
  display: block;
  width: 290rpx;
  height: 290rpx;
}

.orb-status {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 600;
  text-align: center;
}

/* ── Quick Row ── */
.quick-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 8rpx 28rpx;
  flex-shrink: 0;
}

.btn-loc {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #EFF6FF;
  color: #2563EB;
  font-size: 27rpx;
  font-weight: 600;
  border: 2rpx solid #BFDBFE;
  flex-shrink: 0;
}

.btn-example {
  flex: 1;
  height: 68rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #DBEAFE;
  display: flex;
  align-items: center;
  gap: 10rpx;
  overflow: hidden;
}

.example-label {
  font-size: 22rpx;
  color: #2563EB;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.7);
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.example-text {
  font-size: 26rpx;
  color: #1E40AF;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── Voice Bar ── */
.voice-bar {
  padding: 12rpx 28rpx calc(22rpx + env(safe-area-inset-bottom));
  background: rgba(248, 249, 255, 0.96);
  flex-shrink: 0;
}

.ctrl-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.side-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 118rpx;
  flex-shrink: 0;
}

.side-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #EFF6FF;
  border: 2rpx solid #BFDBFE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.side-icon {
  font-size: 30rpx;
  font-weight: 700;
  color: #2563EB;
}

.side-label {
  font-size: 22rpx;
  color: #6B7280;
  font-weight: 600;
}

.mic-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: 1;
}

.mic-core {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1E40AF, #3B82F6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(37, 99, 235, 0.38);
  transition: transform 0.15s;
}

.mic-btn.mic-on .mic-core {
  background: linear-gradient(135deg, #DC2626, #F87171);
  box-shadow: 0 12rpx 40rpx rgba(220, 38, 38, 0.38);
  transform: scale(1.06);
}

.mic-char {
  font-size: 44rpx;
  color: #fff;
  font-weight: 700;
}

.mic-label {
  font-size: 25rpx;
  color: #6B7280;
  font-weight: 600;
}

.skip-btn {
  display: block;
  text-align: center;
  color: #9CA3AF;
  font-size: 25rpx;
  font-weight: 600;
  margin-top: 10rpx;
  padding: 8rpx 0;
}

/* ── Text Bar ── */
.text-bar {
  padding: 12rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(248, 249, 255, 0.96);
  flex-shrink: 0;
}

.text-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 999rpx;
  border: 2rpx solid #DBEAFE;
  padding: 8rpx 8rpx 8rpx 24rpx;
}

.text-input {
  flex: 1;
  height: 68rpx;
  font-size: 30rpx;
  color: #1E3A8A;
  font-weight: 600;
  background: transparent;
  border: none;
  min-width: 0;
}

.text-ph {
  color: #9CA3AF;
  font-weight: 400;
}

.send-btn {
  height: 70rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1E40AF, #3B82F6);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.switch-btn {
  display: block;
  text-align: center;
  margin-top: 12rpx;
  color: #6B7280;
  font-size: 27rpx;
  font-weight: 600;
}

/* ── Manual Form ── */
.form-scroll { flex: 1; min-height: 0; }

.form-body { padding: 16rpx 28rpx 40rpx; }

.form-row { margin-bottom: 28rpx; }

.form-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.form-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E3A8A;
}

.req { color: #EF4444; font-weight: 700; font-size: 28rpx; }

.form-opt { color: #9CA3AF; font-size: 26rpx; font-weight: 500; }

.form-input {
  width: 100%;
  height: 86rpx;
  background: #fff;
  border-radius: 14rpx;
  border: 2rpx solid #DBEAFE;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1E3A8A;
  font-weight: 600;
  box-sizing: border-box;
}

.form-input-flex {
  flex: 1;
  width: auto;
  border-radius: 14rpx 0 0 14rpx;
}

.form-input-mt { margin-top: 12rpx; }

.form-loc-row {
  display: flex;
  align-items: center;
}

.form-loc-btn {
  height: 86rpx;
  padding: 0 24rpx;
  background: #EFF6FF;
  border: 2rpx solid #BFDBFE;
  border-left: none;
  border-radius: 0 14rpx 14rpx 0;
  color: #2563EB;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.chip {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #EFF6FF;
  border: 2rpx solid #BFDBFE;
  color: #1E40AF;
  font-size: 27rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
}

.chip-on {
  background: linear-gradient(135deg, #1E40AF, #3B82F6);
  color: #fff;
  border-color: transparent;
}

.form-note {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
  display: block;
}

.form-submit {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1E40AF, #3B82F6);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(37, 99, 235, 0.32);
}

.form-skip {
  width: 100%;
  height: 72rpx;
  border-radius: 999rpx;
  color: #9CA3AF;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

/* ── Animations ── */
@keyframes dotBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.04); }
}
