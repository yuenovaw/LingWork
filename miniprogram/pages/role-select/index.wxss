page {
  background: #f6f9ff;
}

.page {
  min-height: 100vh;
  padding: 56rpx 34rpx 48rpx;
  box-sizing: border-box;
  color: #222;
}

.step-pill {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #3468a8;
  font-size: 27rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.22;
}

.sub {
  color: #6e6861;
  font-size: 31rpx;
  line-height: 1.55;
  margin: 18rpx 0 34rpx;
}

.role-card {
  min-height: 162rpx;
  border: 3rpx solid #dbe8fb;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx 24rpx;
  margin-bottom: 26rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 26rpx rgba(68, 111, 171, 0.06);
}

.role-card.employer-card.active {
  border-color: #67be86;
  background: #f1faf4;
  box-shadow: 0 12rpx 28rpx rgba(103, 190, 134, 0.14);
}

.role-card.worker-card.active {
  border-color: #5b8def;
  background: #eef5ff;
  box-shadow: 0 12rpx 28rpx rgba(91, 141, 239, 0.16);
}

.role-card.employer-card.active .briefcase .handle,
.role-card.employer-card.active .briefcase .case {
  border-color: #3f8b62;
}

.role-card.worker-card.active .person-icon .head,
.role-card.worker-card.active .person-icon .shoulder {
  border-color: #3468a8;
}

.icon {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.briefcase .handle {
  position: absolute;
  left: 22rpx;
  top: 4rpx;
  width: 28rpx;
  height: 18rpx;
  border: 5rpx solid #222;
  border-bottom: none;
  border-radius: 6rpx 6rpx 0 0;
}

.briefcase .case {
  position: absolute;
  left: 5rpx;
  top: 20rpx;
  width: 62rpx;
  height: 48rpx;
  border: 5rpx solid #222;
  border-radius: 8rpx;
}

.person-icon .head {
  position: absolute;
  left: 22rpx;
  top: 4rpx;
  width: 30rpx;
  height: 30rpx;
  border: 5rpx solid #222;
  border-radius: 50%;
}

.person-icon .shoulder {
  position: absolute;
  left: 8rpx;
  top: 42rpx;
  width: 58rpx;
  height: 32rpx;
  border: 5rpx solid #222;
  border-bottom: none;
  border-radius: 36rpx 36rpx 0 0;
}

.role-main {
  flex: 1;
}

.role-title {
  font-size: 37rpx;
  font-weight: 800;
}

.role-desc {
  color: #6e6861;
  font-size: 29rpx;
  line-height: 1.45;
  margin-top: 10rpx;
}

.arrow {
  color: #222;
  font-size: 48rpx;
  flex-shrink: 0;
}

.agreement-line {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  color: #4f4a45;
  font-size: 29rpx;
  line-height: 1.55;
  margin: 38rpx 0 28rpx;
}

.agreement-line text {
  color: #222;
  font-weight: 800;
  text-decoration: underline;
}

.check {
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  border: 4rpx solid #777;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.check.checked {
  border-color: #3468a8;
  background: #3468a8;
  color: #fff;
}

.next-btn {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  border-radius: 14rpx;
  background: #ece8df;
  color: #928a80;
  font-size: 34rpx;
  font-weight: 800;
}

.next-btn.enabled {
  background: #5b8def;
  color: #fff;
  box-shadow: 0 12rpx 26rpx rgba(91, 141, 239, 0.22);
}

.next-btn.enabled.employer-next {
  background: #67be86;
  box-shadow: 0 12rpx 26rpx rgba(103, 190, 134, 0.22);
}

.helper {
  text-align: center;
  color: #7a746d;
  font-size: 26rpx;
  margin-top: 22rpx;
}
