/* 发布图标 (+ 圆形) */
.svg-plus {
  width: 24px;
  height: 24px;
  background-color: #9CA3AF;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.svg-plus::before,
.svg-plus::after {
  content: '';
  position: absolute;
  background-color: #F7FCF9;
}

.svg-plus::before {
  width: 12px;
  height: 2px;
}

.svg-plus::after {
  width: 2px;
  height: 12px;
}

.svg-plus.active {
  background-color: #67BE86;
}

